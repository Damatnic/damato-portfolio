# Copy into `.env.local` for local dev. On Vercel, set these per-environment
# (Production / Preview / Development) — see AGENTS.md for the table + CLI.
# `.env.local` is gitignored; never commit real secrets.
#
# Quickest full local setup (analytics KV + E2E auth):
#   vercel link && vercel env pull .env.local
#   vercel env pull .env.production.pulled --environment=production
#   node scripts/merge-local-env.mjs

# ── Site ────────────────────────────────────────────────────────────────────
# Canonical origin, no trailing slash. Drives the canonical/og:url, sitemap,
# robots host, analytics self-referrer filter, and the cron digest dashboard
# link. Local: http://localhost:3000 (match your dev port). Production/Preview:
# https://nicholasdamato.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# IANA timezone for analytics day/hour bucketing. Defaults to America/Chicago.
NEXT_PUBLIC_SITE_TZ=America/Chicago

# ── Analytics storage (Vercel KV / Upstash Redis) ────────────────────────────
# Optional locally — analytics degrades gracefully when unset (events log to the
# console instead of persisting). Provision via Vercel Storage / Upstash.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Auth secrets ─────────────────────────────────────────────────────────────
# Gate for /admin/analytics?secret=… (timing-safe compared). Use a long random value.
ANALYTICS_SECRET=
# Bearer token Vercel Cron sends to /api/cron/digest. Set the same value in Vercel.
CRON_SECRET=
# Key for the GET /api/trackers-summary?key=… feed.
TRACKERS_ANALYTICS_KEY=

# ── Email (Resend) ───────────────────────────────────────────────────────────
# Optional — when unset, the daily digest + resume-download alerts are skipped.
RESEND_API_KEY=
# Recipient for the digest and resume-download notifications.
NOTIFY_EMAIL_TO=
# Verified sender. Defaults to onboarding@resend.dev if unset.
NOTIFY_EMAIL_FROM=

# Note: VERCEL_OIDC_TOKEN is injected automatically by `vercel dev` / Vercel —
# do not set it by hand.
